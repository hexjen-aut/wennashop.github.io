// Edge Function Supabase : generate-sitemap
// Deploy : supabase functions deploy generate-sitemap
// URL : https://aakxoydznmybstfozjte.supabase.co/functions/v1/generate-sitemap

import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

const BASE_URL = 'https://wennashop.netlify.app';

const STATIC_PAGES = [
  { url: '/',              priority: '1.0', changefreq: 'daily'   },
  { url: '/boutique.html', priority: '0.9', changefreq: 'daily'   },
  { url: '/recherche.html',priority: '0.7', changefreq: 'weekly'  },
  { url: '/Quetes.html',   priority: '0.6', changefreq: 'weekly'  },
];

Deno.serve(async (req) => {
  const headers = {
    'Content-Type': 'application/xml; charset=utf-8',
    'Cache-Control': 'public, max-age=21600',
  };

  try {
    const supabase = createClient(
      Deno.env.get('SUPABASE_URL'),
      Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')
    );

    const { data: products, error } = await supabase
      .from('products')
      .select('id, updated_at, categorie')
      .eq('statut', 'actif')
      .order('updated_at', { ascending: false });

    if (error) throw error;

    const categories = [...new Set((products || []).map(p => p.categorie).filter(Boolean))];
    const today = new Date().toISOString().split('T')[0];

    let xml = `<?xml version="1.0" encoding="UTF-8"?>\n<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n`;

    for (const page of STATIC_PAGES) {
      xml += `  <url><loc>${BASE_URL}${page.url}</loc><lastmod>${today}</lastmod><changefreq>${page.changefreq}</changefreq><priority>${page.priority}</priority></url>\n`;
    }

    for (const cat of categories) {
      const slug = cat.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-');
      xml += `  <url><loc>${BASE_URL}/boutique.html?categorie=${slug}</loc><lastmod>${today}</lastmod><changefreq>daily</changefreq><priority>0.8</priority></url>\n`;
    }

    for (const product of (products || [])) {
      const lastmod = product.updated_at ? product.updated_at.split('T')[0] : today;
      xml += `  <url><loc>${BASE_URL}/detail_produit.html?id=${product.id}</loc><lastmod>${lastmod}</lastmod><changefreq>weekly</changefreq><priority>0.7</priority></url>\n`;
    }

    xml += `</urlset>`;
    return new Response(xml, { headers });

  } catch (err) {
    const fallback = `<?xml version="1.0" encoding="UTF-8"?>\n<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n  <url><loc>${BASE_URL}/</loc><priority>1.0</priority></url>\n  <url><loc>${BASE_URL}/boutique.html</loc><priority>0.9</priority></url>\n</urlset>`;
    return new Response(fallback, { headers });
  }
});